# ===========================================
# Air Products - Variables de entorno
# Local: .env.local | Vercel: Project Settings → Environment Variables
# ===========================================

# --- Autenticación Admin ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambiar_por_contraseña_segura
ADMIN_SESSION_SECRET=generar_string_aleatorio_largo_minimo_32_caracteres

# --- Google Gemini (redacción, scoring y chat) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Gmail API (envío de emails) ---
GMAIL_SENDER=lautaro.figueroa@libertyclub.io

# Opción A — OAuth2 (recomendado para empezar)
# 1. Google Cloud Console → Gmail API → Credenciales OAuth (tipo Web)
# 2. URIs de redirección autorizadas (ambas):
#    http://localhost:3000/api/admin/gmail/oauth/callback
#    https://air-products.vercel.app/api/admin/gmail/oauth/callback
# 3. npm run dev → /admin → conectar Gmail, o npm run gmail:auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# GOOGLE_REDIRECT_URI=  # opcional, override del callback automático

# Opción B — Cuenta de servicio + delegación (Workspace, producción)
# Admin Console → Seguridad → Controles de API → Delegación en todo el dominio
# Scope: https://www.googleapis.com/auth/gmail.send
# GOOGLE_SERVICE_ACCOUNT_EMAIL=admin-mail@proyecto.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Umbral mínimo de calidad para enviar emails (0-100) ---
EMAIL_SCORE_THRESHOLD=70

# --- Vercel Blob (producción) ---
# Crear store con acceso PRIVATE (Storage → Blob → Private). No se puede cambiar después.
# BLOB_READ_WRITE_TOKEN=  # se inyecta al conectar el store al proyecto
# BLOB_ACCESS=public      # solo si el store ya es public (no recomendado para datos admin)
